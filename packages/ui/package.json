{
  "name": "@unimatrix/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared ShadCN-based UI primitives for the Unimatrix monorepo.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
