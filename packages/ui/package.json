    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "recharts": "2.15.4",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
