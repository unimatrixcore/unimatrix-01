{
  "name": "@unimatrix/content",
  "version": "0.1.0",
  "private": true,
  "description": "Typed content system boundary for repo-backed authored content.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@unimatrix/config-eslint": "workspace:*",
    "@unimatrix/config-typescript": "workspace:*",
    "eslint": "^9.36.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
