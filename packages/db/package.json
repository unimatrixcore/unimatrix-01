{
  "name": "@unimatrix/db",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal persistence baseline for Drizzle ORM and SQLite in the Unimatrix monorepo.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "drizzle"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "@unimatrix/config-eslint": "workspace:*",
    "@unimatrix/config-typescript": "workspace:*",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.36.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
