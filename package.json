{
  "name": "unimatrix-01",
  "version": "0.1.0",
  "private": true,
  "description": "Initial monorepo foundation for the Unimatrix ecosystem.",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22 <23",
    "pnpm": "10.30.3"
  },
  "scripts": {
    "dev": "node ./infra/scripts/dev.mjs",
    "setup:local": "node ./infra/scripts/setup-local.mjs",
    "setup:worktree": "node ./infra/scripts/setup-worktree.mjs",
    "db:migrate": "pnpm --filter @unimatrix/db db:migrate",
    "db:generate": "pnpm --filter @unimatrix/db db:generate",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint typecheck test",
    "verify": "turbo run build lint typecheck test"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "eslint": "^9.36.0",
    "jsdom": "^26.1.0",
    "turbo": "^2.8.14",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
