# Required: Clerk publishable key for this Clerk instance. There is no
# default — the app throws a clear config error at runtime if this is
# absent or empty. See `@unimatrix/auth`'s README for how to provision a
# Clerk instance and customize its session token.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Optional local-development browser runtime base URL for API requests.
VITE_API_BASE_URL=/api

# Optional Vite dev-server proxy target used during local development only.
VITE_API_TARGET=http://127.0.0.1:3001
