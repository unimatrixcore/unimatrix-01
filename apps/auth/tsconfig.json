{
  "extends": "@unimatrix/config-typescript/vite-app.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@unimatrix/api-client": ["../../packages/api-client/src/index.ts"],
      "@unimatrix/auth/react": ["../../packages/auth/src/react.tsx"],
      "@unimatrix/auth": ["../../packages/auth/src/index.ts"],
      "@unimatrix/shared": ["../../packages/shared/src/index.ts"],
      "@unimatrix/ui/public": ["../../packages/ui/src/public.ts"],
      "@unimatrix/ui": ["../../packages/ui/src/index.ts"]
    },
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
