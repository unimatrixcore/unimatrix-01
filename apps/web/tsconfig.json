{
  "extends": "@unimatrix/config-typescript/vite-app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@unimatrix/api-client": ["../../packages/api-client/src/index.ts"],
      "@unimatrix/content": ["../../packages/content/src/index.ts"],
      "@unimatrix/shared": ["../../packages/shared/src/index.ts"],
      "@unimatrix/ui": ["../../packages/ui/src/index.ts"]
    },
    "types": ["vite/client", "node"]
  },
  "include": [
    "e2e/**/*.ts",
    "playwright.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
