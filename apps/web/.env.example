# Optional local-development browser runtime base URL for API requests.
# Deployment-oriented examples live in `apps/web/.env.production.example`.
VITE_API_BASE_URL=/api

# Optional Vite dev-server proxy target used during local development only.
VITE_API_TARGET=http://127.0.0.1:3001

# Optional Clerk publishable key. Clerk auth is entirely OPTIONAL for this
# public site: leave this unset and the app behaves exactly as it does
# today (no Clerk JS involved, no header sign-in affordance). Setting it
# enables auth (a header sign-in link/UserButton and token-bearing API
# calls via useApiClient()).
# VITE_CLERK_PUBLISHABLE_KEY=

# Optional URL of the separate Clerk-backed accounts app that "Sign in"
# links point to. Only meaningful when VITE_CLERK_PUBLISHABLE_KEY is set.
VITE_AUTH_APP_URL=https://auth.unimatrix-01.dev
