{
  "name": "@unimatrix/web",
  "version": "0.1.0",
  "private": true,
  "description": "Vite-based web app shell for the Unimatrix monorepo.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "tmp_dir=$(mktemp -d); trap 'rm -rf \"$tmp_dir\"' EXIT; tsc -p tsconfig.test.json --outDir \"$tmp_dir\" && node --test $tmp_dir/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.166.6",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unimatrix/config-eslint": "workspace:*",
    "@unimatrix/config-typescript": "workspace:*",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.36.0",
    "shadcn": "^4.0.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.6",
    "@unimatrix/api-client": "workspace:*",
    "@unimatrix/ui": "workspace:^",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
