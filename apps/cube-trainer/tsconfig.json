{
  "extends": "@unimatrix/config-typescript/vite-app.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@unimatrix/ui/public": ["../../packages/ui/src/public.ts"],
      "@unimatrix/ui": ["../../packages/ui/src/index.ts"]
    },
    "types": ["vite/client", "node"]
  },
  "include": [
    "e2e/**/*.ts",
    "playwright.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
