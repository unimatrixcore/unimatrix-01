    "@tanstack/router-plugin": "^1.166.6",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unimatrix/config-eslint": "workspace:*",
    "@unimatrix/config-typescript": "workspace:*",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.36.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@remixicon/react": "^4.9.0",
