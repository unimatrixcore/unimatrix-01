# Example production runtime config for the API.
# Set these values in your deployment environment instead of committing a live `.env.production`.
# `CORS_ALLOWED_ORIGINS` fully replaces the repo defaults when it is set.
# Add the omnimatrix.dev origins here if or when that hostname becomes public for v1.
HOST=0.0.0.0
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
TRUST_PROXY=1
CORS_ALLOWED_ORIGINS=https://unimatrix-01.dev,https://*.unimatrix-01.dev

# Maximum accepted size, in bytes, for a single per-user file upload
# (POST /me/files). Defaults to 5242880 (5 MiB) when unset.
MAX_UPLOAD_BYTES=5242880

# CLERK_SECRET_KEY, CLERK_PUBLISHABLE_KEY, and CLERK_JWT_KEY are all
# required in production. Set real values in your deployment environment;
# never commit real secrets.
CLERK_SECRET_KEY=sk_live_placeholder
CLERK_PUBLISHABLE_KEY=pk_live_placeholder
CLERK_JWT_KEY=jwt_key_placeholder
