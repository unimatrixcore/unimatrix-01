{
  "name": "@unimatrix/api",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Fastify API shell for the Unimatrix monorepo.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "fastify": "^5.6.1",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@unimatrix/config-eslint": "workspace:*",
    "@unimatrix/config-typescript": "workspace:*",
    "eslint": "^9.36.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
