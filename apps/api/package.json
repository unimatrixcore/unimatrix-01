{
  "name": "@unimatrix/api",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Fastify API shell for the Unimatrix monorepo.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
