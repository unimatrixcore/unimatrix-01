# Optional local-development runtime config for the API.
# This file is auto-bootstrapped by `pnpm dev` and `pnpm setup:local` when missing.
# Deployment-oriented examples live in `apps/api/.env.production.example`.
# The API startup entrypoint auto-loads `apps/api/.env` when this file is present.
HOST=127.0.0.1
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
TRUST_PROXY=false

# Maximum accepted size, in bytes, for a single per-user file upload
# (POST /me/files). Defaults to 5242880 (5 MiB) when unset.
# MAX_UPLOAD_BYTES=5242880

# Clerk auth is optional in development: leave all three unset to run
# without auth, or set all three (never just some) to enable it locally.
# Get real values from the Clerk dashboard; never commit real secrets.
# CLERK_SECRET_KEY=sk_test_placeholder
# CLERK_PUBLISHABLE_KEY=pk_test_placeholder
# CLERK_JWT_KEY=jwt_key_placeholder
